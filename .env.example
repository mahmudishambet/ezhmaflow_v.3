PORT=7575

# Smart dual storage configuration
# Threshold (percent) at which new uploads switch from system disk to additional disk
SYSTEM_DISK_UPLOAD_THRESHOLD=80

# System (boot) disk upload path - used when system disk usage is below the threshold
SYSTEM_UPLOAD_PATH=/www/wwwroot/ezhmaflow_v3/public/uploads_system

# Additional disk mount path - used when system disk reaches the threshold
ADDITIONAL_STORAGE_PATH=/mnt/ezhma-data

# Legacy backup path - read-only fallback for streaming old videos
LEGACY_UPLOAD_PATH=/www/wwwroot/ezhmaflow_v3/public/uploads_backup