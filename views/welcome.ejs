<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Welcome - Ezhma Studio Manager</title>
  <link rel="icon" href="/images/logo-only.png" type="image/png">
  <link rel="preload" href="/images/logo-only.png" as="image" type="image/png">
  <link rel="alternate icon" href="/images/favicon.ico" type="image/x-icon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.30.0/tabler-icons.min.css">
  <link rel="stylesheet" href="/css/styles.css">
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        fontFamily: {
          'inter': ['Inter', 'sans-serif'],
          'sans': ['Inter', 'system-ui', 'sans-serif']
        },
        extend: {
          boxShadow: {
            'md': '0 10px 30px rgba(0,0,0,0.25)',
            'lg': '0 10px 30px rgba(0,0,0,0.25)',
            'xl': '0 10px 30px rgba(0,0,0,0.25)',
          },
          colors: {
            'primary': '#7C3AED',
            'secondary': '#6D28D9',
            'dark': {
              '900': '#080D1A',
              '800': '#0F172A',
              '700': '#1A1E2B',
              '600': '#20232E',
              '500': '#374151',
              '400': '#94A3B8',
              '300': '#CBD5E1',
              '200': '#E2E8F0',
              '100': '#F8FAFC',
            },
            'gray': {
              '900': '#080D1A',
              '800': '#1A1E2B',
              '700': 'rgba(255,255,255,0.06)',
              '600': 'rgba(255,255,255,0.08)',
              '500': '#4B5563',
              '400': '#94A3B8',
              '300': '#CBD5E1',
              '200': '#E2E8F0',
              '100': '#F8FAFC',
              '50': '#F9FAFB',
            }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-dark-900 text-white font-inter" style="background: linear-gradient(135deg, #080D1A 0%, #0F172A 100%);">
  <div class="min-h-screen flex flex-col items-center justify-center px-6 py-10">
    <div class="w-full max-w-md text-center">
      <div class="mb-8">
        <img src="/images/logo-only.png" alt="Ezhma Studio" class="w-20 h-20 mx-auto mb-6 object-contain">
        <h1 class="text-3xl font-bold mb-3">Welcome to Ezhma Studio Manager</h1>
      </div>
      <div class="bg-gray-800 rounded-xl p-6 mb-6 border border-purple-500/10">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-purple-500 to-violet-600 flex items-center justify-center mx-auto mb-4">
          <i class="ti ti-check text-3xl text-white"></i>
        </div>
        <p class="text-gray-300 text-sm mb-2 font-medium">
          Akun Anda berhasil dibuat! 🎉
        </p>
        <p class="text-gray-400 text-sm mb-6">
          Selamat datang di Ezhma Studio Manager. Anda sekarang bisa mulai streaming ke berbagai platform.
        </p>
        
        <div class="grid grid-cols-2 gap-3 mb-6">
          <div class="bg-dark-700 rounded-lg p-3 text-center">
            <i class="ti ti-broadcast text-purple-400 text-xl mb-1"></i>
            <p class="text-xs text-gray-400">Multi-Platform</p>
          </div>
          <div class="bg-dark-700 rounded-lg p-3 text-center">
            <i class="ti ti-calendar-event text-purple-400 text-xl mb-1"></i>
            <p class="text-xs text-gray-400">Scheduled</p>
          </div>
          <div class="bg-dark-700 rounded-lg p-3 text-center">
            <i class="ti ti-brand-telegram text-purple-400 text-xl mb-1"></i>
            <p class="text-xs text-gray-400">Telegram Alerts</p>
          </div>
          <div class="bg-dark-700 rounded-lg p-3 text-center">
            <i class="ti ti-playlist text-purple-400 text-xl mb-1"></i>
            <p class="text-xs text-gray-400">Playlist Support</p>
          </div>
        </div>
      </div>

      <div class="mb-4">
        <p id="countdown-text" class="text-gray-500 text-sm">
          Redirecting to dashboard in <span id="countdown">5</span> seconds...
        </p>
      </div>
      <a href="/welcome/continue" class="inline-flex items-center justify-center text-primary hover:text-purple-400 font-medium transition-colors">
        Go to Dashboard
        <i class="ti ti-arrow-right ml-2"></i>
      </a>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const icons = document.querySelectorAll('.ti');
      icons.forEach(icon => {
        icon.classList.add('font-loaded');
      });

      confetti({
        particleCount: 50,
        angle: 60,
        spread: 55,
        origin: { x: 0 }
      });
      confetti({
        particleCount: 50,
        angle: 120,
        spread: 55,
        origin: { x: 1 }
      });

      let countdown = 5;
      const countdownElement = document.getElementById('countdown');
      const countdownTextElement = document.getElementById('countdown-text');
      
      const countdownInterval = setInterval(() => {
        countdown--;
        countdownElement.textContent = countdown;
        
        if (countdown <= 0) {
          clearInterval(countdownInterval);
          countdownTextElement.textContent = 'Redirecting now...';
          window.location.href = '/welcome/continue';
        }
      }, 1000);
    });
  </script>
</body>
</html>

